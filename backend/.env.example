APP_NAME=Binance Futures Auto Trading Platform
APP_ENV=local

SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Postgres 비밀번호 (docker-compose 와 DATABASE_URL 양쪽에서 사용).
# testnet/local 은 'postgres' 그대로, mainnet 은 강한 임의값으로 변경.
# DATABASE_URL 의 비번 부분도 같은 값으로 맞춰야 함.
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/binance_auto_trader
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/binance_auto_trader_test
REDIS_URL=redis://redis:6379/0

BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_TESTNET_BASE_URL=https://testnet.binancefuture.com

ENCRYPTION_KEY=change_me_to_fernet_key

ENABLE_METRICS=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
