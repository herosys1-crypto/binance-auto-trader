# =============================================================================
# Production .env Template (Mainnet 운영용)
# =============================================================================
# 사용법:
#   1. cp .env.production.template .env
#   2. 모든 <PLACEHOLDER> 를 실제 값으로 교체 (각 자격증명은 새로 발급/생성)
#   3. chmod 600 .env
#
# 절대 git 에 commit 하지 말 것 (.gitignore 에 .env 등록됨).
# =============================================================================

APP_NAME=Binance Futures Auto Trading Platform
APP_ENV=production

# -----------------------------------------------------------------------------
# JWT — 새 SECRET_KEY 생성:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------------
SECRET_KEY=<NEW_RANDOM_48_BYTES>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Database — Neon Cloud Postgres (외부 관리형, 자동 백업)
# Neon UI 에서 Reset password 후 새 connection string 사용.
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=<NOT_USED_IF_NEON>
DATABASE_URL=postgresql+psycopg2://neondb_owner:<NEW_NEON_PASSWORD>@<HOST>.neon.tech/neondb?sslmode=require

TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/binance_auto_trader_test
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Binance API — Mainnet
# 코드 내부에서 exchange_account.is_testnet 으로 분기 (값 둘 다 유지)
# -----------------------------------------------------------------------------
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_TESTNET_BASE_URL=https://testnet.binancefuture.com

# -----------------------------------------------------------------------------
# ENCRYPTION_KEY — 거래소 API key/secret 암호화용 (Fernet)
# 새 키 생성:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 옛 키로 암호화된 DB 데이터가 있다면 마이그레이션 후 새 키 적용
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=<NEW_FERNET_KEY>

ENABLE_METRICS=true

# -----------------------------------------------------------------------------
# Telegram — 새 봇 토큰 (BotFather → /mybots → Revoke current token)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<NEW_BOTFATHER_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_CHAT_ID>

# -----------------------------------------------------------------------------
# Sentry (Production 권장)
# https://sentry.io → Create Project → Python/FastAPI → DSN 복사
# -----------------------------------------------------------------------------
SENTRY_DSN=<HTTPS_DSN_OR_EMPTY>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# -----------------------------------------------------------------------------
# Daily loss limit — USDT 양수 (5-04 신규, PR #1).
# - 활성 strategy 의 unrealized + 일일 누적 realized 합이 이 값 초과 시 자동 kill-switch.
# - 비워두거나 0 이면 비활성 (deploy-safe default).
# - 계정별 override (exchange_accounts.daily_loss_limit_usdt) 가 더 우선.
# 권장: mainnet 첫 거래 자본의 10~20% (예: 자본 $1000 → 한도 $100~200).
# -----------------------------------------------------------------------------
DAILY_LOSS_LIMIT_USDT=

# -----------------------------------------------------------------------------
# Redis password (옵션, 외부 노출 시 필수)
# Production 에선 docker network 내부 접근만 → 비워둬도 안전 (deploy-safe default).
# 단 보안 강화 위해 비밀번호 설정 시:
#   1. REDIS_URL 을 redis://:PASSWORD@redis:6379/0 형식으로
#   2. docker-compose.yml 의 redis service command 에 --requirepass 추가
# -----------------------------------------------------------------------------
# REDIS_PASSWORD=<OPTIONAL>

# -----------------------------------------------------------------------------
# 로컬 db service 용 (Neon Cloud 사용 시 무관, override 로 db service disabled).
# generate-secrets.sh 가 자동 생성한 값 채우기 (혹시 필요할 수 있는 fallback).
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=<NEW_RANDOM_24_BYTES_OR_EMPTY>
